# Grafana Cloud — Prometheus remote_write credentials
# Find these in your Grafana Cloud stack under: Connections > Prometheus
GRAFANA_CLOUD_PROM_URL=https://prometheus-prod-XX-prod-us-east-X.grafana.net/api/prom/push
GRAFANA_CLOUD_PROM_USERNAME=your_numeric_user_id
GRAFANA_CLOUD_PROM_PASSWORD=glc_your_api_token_here

# Local Grafana UI — accessible at http://localhost:3001
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me_strong_password
