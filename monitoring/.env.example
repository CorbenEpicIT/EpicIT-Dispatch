# Grafana Cloud — Loki log forwarding credentials
# Find these in your Grafana Cloud stack under: Connections > Loki
GRAFANA_CLOUD_LOKI_URL=https://logs-prod-036.grafana.net
GRAFANA_CLOUD_LOKI_USERNAME=your_numeric_loki_user_id
GRAFANA_CLOUD_LOKI_PASSWORD=glc_your_api_token_here

# Local Grafana UI — accessible at http://localhost:3001
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me_strong_password
