// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

enum job_status {
  Unscheduled
  Scheduled
  InProgress
  Completed
  Cancelled
}

enum arrival_constraint {
  anytime
  at
  between
  by
}

enum finish_constraint {
  when_done
  at
  by
}

enum discount_type {
  percent
  amount
}

enum line_item_type {
  labor
  material
  equipment
  other
}

enum line_item_source {
  quote
  recurring_plan
  manual          //dispatch
  field_addition  //tech
}

enum visit_status {
  Scheduled
  Driving
  OnSite
  InProgress
  Paused
  Delayed
  Completed
  Cancelled
}

enum request_status {
  New
  Reviewing
  Quoted
  QuoteApproved
  QuoteRejected
  ConvertedToJob
  Cancelled
}

enum quote_status {
  Draft
  Sent
  Viewed
  Approved
  Rejected
  Revised
  Expired
  Cancelled
}

enum priority {
  Low
  Medium
  High
  Urgent
  Emergency
}

enum technician_status {
  Offline
  Available
  Busy
  Break
}

enum recurring_plan_status {
  Active
  Paused
  Completed
  Cancelled
}

enum billing_mode {
  per_visit      
  subscription   
  none          
}

enum invoice_timing {
  on_completion      // Generate invoice when visit completed
  on_schedule_date   // Generate invoice on scheduled date
  manual             // Never auto-generate
}

enum occurrence_status {
  planned 
  generated 
  skipped     
  cancelled   
  completed   
}

enum recurring_frequency {
  daily
  weekly
  monthly
  yearly
}

enum weekday {
  MO
  TU
  WE
  TH
  FR
  SA
  SU
}

enum form_draft_type {
  request
  quote
  job
  job_visit
  recurring_plan
  invoice
}

enum invoice_status {
  Draft
  Sent
  Viewed
  PartiallyPaid
  Paid
  Disputed
  Void
}

enum invoice_schedule_frequency {
  weekly
  biweekly
  monthly
  quarterly
  on_visit_completion
}

enum invoice_schedule_billing_basis {
  fixed_amount
  visit_actuals
  plan_line_items
  invoice
}

/* Add more roles here if needed */
enum DispatcherRole {
  dispatcher
  admin
}


model organization {
  id       String  @id @default(uuid())
  name     String
  tax_rate Decimal @default(0) @db.Decimal(5, 4)

  clients               client[]
  contacts              contact[]
  technicians           technician[]
  dispatchers           dispatcher[]
  inventory_items       inventory_item[]
  logs                  log[]

  requests              request[]
  quotes                quote[]
  jobs                  job[]
  recurring_plans       recurring_plan[]
  form_drafts           form_draft[]
  invoices              invoice[]

  client_notes          client_note[]
  request_notes         request_note[]
  quote_notes           quote_note[]
  job_notes             job_note[]
  recurring_plan_notes  recurring_plan_note[]
  invoice_notes         invoice_note[]
}

// ============================================================================
// Contact
// ============================================================================

model contact {
  id        String  @id @unique @default(uuid())
  organization_id String?
  organization    organization? @relation(fields: [organization_id], references: [id])
  name      String
  email     String?
  phone     String?
  company   String?
  title     String?
  type      String? // "customer", "vendor", "property_manager", "tenant"
  misc_info String? @db.Text
  is_active Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  client_contacts client_contact[]

  @@unique([organization_id, email])
  @@unique([organization_id, phone])

  @@index([email])
  @@index([phone])
  @@index([is_active])
  @@index([organization_id])
}

model client_contact {
  client_id  String
  contact_id String
  client     client  @relation(fields: [client_id], references: [id], onDelete: Cascade)
  contact    contact @relation(fields: [contact_id], references: [id], onDelete: Cascade)

  relationship String  @default("contact")
  is_primary   Boolean @default(false)
  is_billing   Boolean @default(false)

  @@id([client_id, contact_id])
  @@index([contact_id])
}

// ============================================================================
// Client
// ============================================================================

model client {
  id              String   @id @unique @default(uuid())
  organization_id String?
  organization    organization? @relation(fields: [organization_id], references: [id])
  name            String
  address         String
  coords          Json
  is_active       Boolean  @default(true)
  is_tax_exempt   Boolean  @default(false)
  tax_rate        Decimal? @db.Decimal(5, 4)
  created_at      DateTime @default(now())
  last_activity   DateTime @default(now())
  updated_at      DateTime @updatedAt

  contacts        client_contact[]
  requests        request[]
  quotes          quote[]
  jobs            job[]
  notes           client_note[]
  recurring_plans recurring_plan[]
  invoices        invoice[]

  @@index([is_active])
  @@index([is_tax_exempt])
  @@index([created_at])
  @@index([organization_id])
}

model client_note {
  id        String @id @unique @default(uuid())
  organization_id String?
  organization    organization? @relation(fields: [organization_id], references: [id])
  client_id String
  client    client @relation(fields: [client_id], references: [id], onDelete: Cascade)

  content    String   @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  creator_tech_id           String?
  creator_dispatcher_id     String?
  last_editor_tech_id       String?
  last_editor_dispatcher_id String?

  creator_tech           technician? @relation("ClientNoteCreator", fields: [creator_tech_id], references: [id])
  creator_dispatcher     dispatcher? @relation("ClientNoteCreator", fields: [creator_dispatcher_id], references: [id])
  last_editor_tech       technician? @relation("ClientNoteEditor", fields: [last_editor_tech_id], references: [id])
  last_editor_dispatcher dispatcher? @relation("ClientNoteEditor", fields: [last_editor_dispatcher_id], references: [id])

  @@index([client_id])
  @@index([created_at])
}

// ============================================================================
// REQUEST → QUOTE → JOB 
// ============================================================================

model request {
  id        String @id @default(uuid())
  organization_id String?
  organization    organization? @relation(fields: [organization_id], references: [id])
  client_id String
  client    client @relation(fields: [client_id], references: [id])

  title       String
  description String         @db.Text
  priority    priority       @default(Medium)
  address     String?
  coords      Json?
  status      request_status @default(New)
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt

  requires_quote   Boolean  @default(false)
  estimated_value  Decimal? @db.Decimal(10, 2)
  source           String? // "phone", "email", "web"
  source_reference String?

  cancelled_at        DateTime?
  cancellation_reason String?

  quotes       quote[]
  jobs         job[]
  notes        request_note[]
  created_by_dispatcher_id String?
  created_by_dispatcher   dispatcher?    @relation("RequestCreator", fields: [created_by_dispatcher_id], references: [id])
 

  @@index([client_id])
  @@index([status])
  @@index([priority])
  @@index([created_at])
  @@index([updated_at])
  @@index([created_by_dispatcher_id])
  @@index([status, priority]) // Composite for "urgent pending requests"
}

model request_note {
  id         String  @id @default(uuid())
  organization_id String?
  organization    organization? @relation(fields: [organization_id], references: [id])
  request_id String
  request    request @relation(fields: [request_id], references: [id], onDelete: Cascade)

  content    String   @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  creator_tech_id           String?
  creator_dispatcher_id     String?
  last_editor_tech_id       String?
  last_editor_dispatcher_id String?

  creator_tech           technician? @relation("RequestNoteCreator", fields: [creator_tech_id], references: [id])
  creator_dispatcher     dispatcher? @relation("RequestNoteCreator", fields: [creator_dispatcher_id], references: [id])
  last_editor_tech       technician? @relation("RequestNoteEditor", fields: [last_editor_tech_id], references: [id])
  last_editor_dispatcher dispatcher? @relation("RequestNoteEditor", fields: [last_editor_dispatcher_id], references: [id])

  @@index([request_id])
}

model quote {
  id           String   @id @default(uuid())
  organization_id String?
  organization    organization? @relation(fields: [organization_id], references: [id])
  quote_number String   @unique
  client_id    String
  client       client   @relation(fields: [client_id], references: [id])
  request_id   String?
  request      request? @relation(fields: [request_id], references: [id])

  title       String
  description String       @db.Text
  status      quote_status @default(Draft)

  address  String
  coords   Json?
  priority priority @default(Medium)

  is_active         Boolean @default(true)
  version           Int     @default(1)
  previous_quote_id String? @unique
  previous_quote    quote?  @relation("QuoteRevisions", fields: [previous_quote_id], references: [id])
  revised_quote     quote?  @relation("QuoteRevisions")

  subtotal            Decimal @db.Decimal(10, 2)
  tax_rate            Decimal @default(0) @db.Decimal(5, 4)
  tax_amount          Decimal @default(0) @db.Decimal(10, 2)
  discount_type        discount_type?
  discount_value       Decimal?  @db.Decimal(10, 2)  // User input value
  discount_amount      Decimal?  @db.Decimal(10, 2)  // Calculated discount $
  total               Decimal @db.Decimal(10, 2)

  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  sent_at     DateTime?
  viewed_at   DateTime?
  approved_at DateTime?
  rejected_at DateTime?

  valid_until DateTime? //The pricing deadline for the client to accept the quote (revision needed)
  expires_at  DateTime? //The deadline for when the quote is invalid/expired

  rejection_reason String?

  created_by_dispatcher_id String?
  created_by_dispatcher    dispatcher? @relation("QuoteCreator", fields: [created_by_dispatcher_id], references: [id])

  line_items quote_line_item[]
  notes      quote_note[]
  job        job?

  @@index([client_id])
  @@index([request_id])
  @@index([status])
  @@index([is_active])
  @@index([quote_number])
  @@index([created_at])
  @@index([client_id, is_active])
  @@index([request_id, is_active])
}

model quote_line_item {
  id       String @id @default(uuid())
  quote_id String
  quote    quote  @relation(fields: [quote_id], references: [id], onDelete: Cascade)

  name        String
  description String? @db.Text
  quantity    Decimal @db.Decimal(10, 2)
  unit_price  Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)

  item_type  line_item_type?
  sort_order Int     @default(0)

  @@index([quote_id])
  @@index([sort_order])
}

model quote_note {
  id       String @id @default(uuid())
  organization_id String?
  organization    organization? @relation(fields: [organization_id], references: [id])
  quote_id String
  quote    quote  @relation(fields: [quote_id], references: [id], onDelete: Cascade)

  content    String   @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  creator_tech_id           String?
  creator_dispatcher_id     String?
  last_editor_tech_id       String?
  last_editor_dispatcher_id String?

  creator_tech           technician? @relation("QuoteNoteCreator", fields: [creator_tech_id], references: [id])
  creator_dispatcher     dispatcher? @relation("QuoteNoteCreator", fields: [creator_dispatcher_id], references: [id])
  last_editor_tech       technician? @relation("QuoteNoteEditor", fields: [last_editor_tech_id], references: [id])
  last_editor_dispatcher dispatcher? @relation("QuoteNoteEditor", fields: [last_editor_dispatcher_id], references: [id])

  @@index([quote_id])
}

model job {
  id          String   @id @unique @default(uuid())
  organization_id String?
  organization    organization? @relation(fields: [organization_id], references: [id])
  job_number  String   @unique
  name        String
  description String   @db.Text
  priority    priority @default(Medium)
  address     String
  coords      Json

  status job_status @default(Unscheduled)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  completed_at        DateTime?
  cancelled_at        DateTime?
  cancellation_reason String?

  client_id String
  client    client @relation(fields: [client_id], references: [id])
  request_id String?  
  request    request? @relation(fields: [request_id], references: [id])
  quote_id String? @unique // One job per quote
  quote    quote?  @relation(fields: [quote_id], references: [id])
  recurring_plan_id String? @unique
  recurring_plan    recurring_plan? @relation(fields: [recurring_plan_id], references: [id])

  // Financial totals for non-recurring jobs OR
  // aggregated values for recurring job containers
  // For recurring: estimated_total = quote/template total
  // For recurring: actual_total = SUM(completed visit totals)
  subtotal        Decimal  @default(0) @db.Decimal(10, 2)
  tax_rate        Decimal  @default(0) @db.Decimal(5, 4)
  tax_amount      Decimal  @default(0) @db.Decimal(10, 2)
  discount_type   discount_type?
  discount_value  Decimal? @db.Decimal(10, 2)
  discount_amount Decimal? @db.Decimal(10, 2)
  estimated_total Decimal? @db.Decimal(10, 2)
  actual_total    Decimal? @db.Decimal(10, 2)

  visits       job_visit[]
  notes        job_note[]
  line_items   job_line_item[]
  invoice_jobs invoice_job[]

  @@index([client_id])
  @@index([recurring_plan_id])
  @@index([request_id])
  @@index([quote_id])
  @@index([status])
  @@index([priority])
  @@index([created_at])
  @@index([updated_at])

  @@index([client_id, status])
}

model job_line_item {
  id     String @id @default(uuid())
  job_id String
  job    job    @relation(fields: [job_id], references: [id], onDelete: Cascade)

  name        String
  description String? @db.Text
  quantity    Decimal @db.Decimal(10, 2)
  unit_price  Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)

  source    line_item_source
  item_type line_item_type?

  created_at DateTime @default(now())

  @@index([job_id])
}

model job_visit {
  id     String @id @default(uuid())
  job_id String
  job    job    @relation(fields: [job_id], references: [id], onDelete: Cascade)

  name        String?  
  description String?  @db.Text 

  arrival_constraint   arrival_constraint
  finish_constraint    finish_constraint
  
  scheduled_start_at   DateTime
  scheduled_end_at     DateTime
  
  arrival_time         String? // For arrival_constraint = "at"
  arrival_window_start String? // For arrival_constraint = "between"
  arrival_window_end   String? // For arrival_constraint = "between" or "by"
  finish_time          String? // For finish_constraint = "at" or "by"

  actual_start_at      DateTime?
  actual_end_at        DateTime?

  status visit_status @default(Scheduled)

  subtotal        Decimal  @default(0) @db.Decimal(10, 2)
  tax_rate        Decimal  @default(0) @db.Decimal(5, 4)
  tax_amount      Decimal  @default(0) @db.Decimal(10, 2)
  discount_type   discount_type?
  discount_value  Decimal? @db.Decimal(10, 2)
  discount_amount Decimal? @db.Decimal(10, 2)
  total           Decimal  @default(0) @db.Decimal(10, 2)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  visit_techs          job_visit_technician[]
  notes                job_note[]              @relation("VisitNotes")
  recurring_occurrence recurring_occurrence?   @relation("OccurrenceVisit")
  line_items           job_visit_line_item[]
  invoice_visits       invoice_visit[]

  @@index([job_id])
  @@index([status])
  @@index([scheduled_start_at])
  @@index([scheduled_end_at])
  @@index([job_id, scheduled_start_at])
}

model job_visit_line_item {
  id        String   @id @default(uuid())

  visit_id  String
  visit     job_visit @relation(fields: [visit_id], references: [id], onDelete: Cascade)

  name        String
  description String? @db.Text
  quantity    Decimal @db.Decimal(10, 2)
  unit_price  Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)

  source    line_item_source
  item_type line_item_type?

  sort_order Int @default(0)
  created_at DateTime @default(now())

  @@index([visit_id])
  @@index([sort_order])
}

model job_visit_technician {
  visit_id String
  tech_id  String
  visit    job_visit  @relation(fields: [visit_id], references: [id], onDelete: Cascade)
  tech     technician @relation(fields: [tech_id], references: [id])

  @@id([visit_id, tech_id])
  @@index([tech_id])
  @@index([visit_id])
}

model job_note {
  id     String @id @default(uuid())
  organization_id String?
  organization    organization? @relation(fields: [organization_id], references: [id])
  job_id String
  job    job    @relation(fields: [job_id], references: [id], onDelete: Cascade)

  content    String   @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  creator_tech_id           String?
  creator_dispatcher_id     String?
  last_editor_tech_id       String?
  last_editor_dispatcher_id String?

  visit_id String?
  visit    job_visit? @relation("VisitNotes", fields: [visit_id], references: [id], onDelete: Cascade)

  creator_tech           technician? @relation("JobNoteCreator", fields: [creator_tech_id], references: [id])
  creator_dispatcher     dispatcher? @relation("JobNoteCreator", fields: [creator_dispatcher_id], references: [id])
  last_editor_tech       technician? @relation("JobNoteEditor", fields: [last_editor_tech_id], references: [id])
  last_editor_dispatcher dispatcher? @relation("JobNoteEditor", fields: [last_editor_dispatcher_id], references: [id])

  @@index([job_id])
  @@index([visit_id])
}

// ============================================================================
// Recurring events
// ============================================================================

model recurring_plan {
  id              String                  @id @default(uuid())
  organization_id String?
  organization    organization?           @relation(fields: [organization_id], references: [id])
  
  client_id       String
  client          client                  @relation(fields: [client_id], references: [id], onDelete: Cascade)

  job_container job?
  
  name            String
  description     String                  @db.Text
  address         String
  coords          Json?
  priority        priority                @default(Medium)
  
  status          recurring_plan_status   @default(Active)
  starts_at       DateTime
  ends_at         DateTime?               // null = indefinite
  timezone        String                  @default("America/Chicago") // IANA timezone
  generation_window_days Int @default(90) // How far ahead to generate
  min_advance_days       Int @default(14) // Minimum notice for scheduling
  
  // Billing configuration (future-ready)
  billing_mode    billing_mode            @default(per_visit)
  invoice_timing  invoice_timing          @default(on_completion)
  auto_invoice    Boolean                 @default(false)
  
  created_at      DateTime                @default(now())
  updated_at      DateTime                @updatedAt
  created_by_dispatcher_id String?
  created_by_dispatcher    dispatcher?    @relation("RecurringPlanCreator", fields: [created_by_dispatcher_id], references: [id])
  
  rules            recurring_rule[]
  occurrences      recurring_occurrence[]
  line_items       recurring_plan_line_item[]
  notes            recurring_plan_note[]
  invoice_schedule invoice_schedule?
  invoices         invoice[]

  @@index([client_id])
  @@index([status])
  @@index([organization_id])
  @@index([starts_at])
  @@index([client_id, status])
}

model recurring_rule {
  id                String         @id @default(uuid())
  recurring_plan_id String
  recurring_plan    recurring_plan @relation(fields: [recurring_plan_id], references: [id], onDelete: Cascade)
  
  frequency         recurring_frequency
  interval          Int            @default(1) // every X days/weeks/months/years
  
  by_weekday        recurring_rule_weekday[]
  by_month_day      Int?           // 1-31 for monthly
  by_month          Int?           // 1-12 for yearly
  
  arrival_constraint   arrival_constraint
  finish_constraint    finish_constraint
  
  arrival_time         String? // For arrival_constraint = "at"
  arrival_window_start String? // For arrival_constraint = "between"
  arrival_window_end   String? // For arrival_constraint = "between" or "by"
  finish_time          String? // For finish_constraint = "at" or "by"
  
  created_at        DateTime       @default(now())
  
  @@index([recurring_plan_id])
}

model recurring_rule_weekday {
  id                String         @id @default(uuid())
  recurring_rule_id String
  recurring_rule    recurring_rule @relation(fields: [recurring_rule_id], references: [id], onDelete: Cascade)

  weekday           weekday

  @@unique([recurring_rule_id, weekday])
  @@index([weekday])
}

// Generated occurrences (planned vs actual)
model recurring_occurrence {
  id                  String            @id @default(uuid())
  recurring_plan_id   String
  recurring_plan      recurring_plan    @relation(fields: [recurring_plan_id], references: [id], onDelete: Cascade)
  
  occurrence_start_at DateTime
  occurrence_end_at   DateTime
  
  status              occurrence_status @default(planned)
  
  // Link to actual generated visit
  job_visit_id        String?           @unique
  job_visit           job_visit?        @relation("OccurrenceVisit", fields: [job_visit_id], references: [id])
  
  generated_at        DateTime?
  completed_at        DateTime?
  skipped_at          DateTime?
  skip_reason         String?
  
  // Template versioning (optional)
  template_version    Int               @default(1)
  
  created_at          DateTime          @default(now())
  
  @@unique([recurring_plan_id, occurrence_start_at])
  @@index([recurring_plan_id])
  @@index([occurrence_start_at])
  @@index([status])
  @@index([job_visit_id])
}

// Template pricing for recurring work
model recurring_plan_line_item {
  id                String         @id @default(uuid())
  recurring_plan_id String
  recurring_plan    recurring_plan @relation(fields: [recurring_plan_id], references: [id], onDelete: Cascade)
  
  name              String
  description       String?        @db.Text
  quantity          Decimal        @db.Decimal(10, 2)
  unit_price        Decimal        @db.Decimal(10, 2)
  
  item_type         line_item_type?
  sort_order        Int            @default(0)
  
  created_at        DateTime       @default(now())
  
  @@index([recurring_plan_id])
  @@index([sort_order])
}

model recurring_plan_note {
  id                String         @id @default(uuid())
  organization_id String?
  organization    organization? @relation(fields: [organization_id], references: [id])
  recurring_plan_id String
  recurring_plan    recurring_plan @relation(fields: [recurring_plan_id], references: [id], onDelete: Cascade)
  
  content           String         @db.Text
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt
  
  creator_tech_id           String?
  creator_dispatcher_id     String?
  last_editor_tech_id       String?
  last_editor_dispatcher_id String?
  
  creator_tech           technician? @relation("RecurringPlanNoteCreator", fields: [creator_tech_id], references: [id])
  creator_dispatcher     dispatcher? @relation("RecurringPlanNoteCreator", fields: [creator_dispatcher_id], references: [id])
  last_editor_tech       technician? @relation("RecurringPlanNoteEditor", fields: [last_editor_tech_id], references: [id])
  last_editor_dispatcher dispatcher? @relation("RecurringPlanNoteEditor", fields: [last_editor_dispatcher_id], references: [id])
  
  @@index([recurring_plan_id])
}

// ============================================================================
// FORM DRAFTS
// ============================================================================

model form_draft {
  id               String          @id @default(uuid())
  organization_id  String?
  organization     organization?   @relation(fields: [organization_id], references: [id])

  form_type        form_draft_type
  label            String          // Derived display name, stored at save time
  payload          Json            // Full form state — opaque to backend, typed on frontend
  entity_context_id String?        // Parent entity id: job_id for job_visit, request_id for quote, etc.

  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt

  @@index([form_type])
  @@index([organization_id, form_type])
  @@index([entity_context_id])
  @@index([updated_at])
}


// ============================================================================
// INVENTORY 
// ============================================================================

model inventory_item {
  id          String @id @unique @default(uuid())
  organization_id String?
  organization    organization? @relation(fields: [organization_id], references: [id])
  name        String
  description String @db.Text
  location    String
  quantity    Int    @default(0)

  unit_price Decimal? @db.Decimal(10, 2)
  cost       Decimal? @db.Decimal(10, 2)
  sku        String?  @unique
  is_active  Boolean  @default(true)
  low_stock_threshold Int?

  @@index([sku])
  @@index([is_active])
  @@index([organization_id])
}

// ============================================================================
// USERS
// ============================================================================

model technician {
  id          String            @id @unique @default(uuid())
  organization_id String?
  organization    organization? @relation(fields: [organization_id], references: [id])
  name        String
  email       String            @unique
  phone       String
  password    String
  title       String
  description String
  status      technician_status @default(Offline)
  hire_date   DateTime
  coords      Json              @default("{}")
  last_login  DateTime          @default(now())

  visit_techs job_visit_technician[]

  created_client_notes      client_note[]  @relation("ClientNoteCreator")
  last_edited_client_notes  client_note[]  @relation("ClientNoteEditor")
  created_job_notes         job_note[]     @relation("JobNoteCreator")
  last_edited_job_notes     job_note[]     @relation("JobNoteEditor")
  created_request_notes     request_note[] @relation("RequestNoteCreator")
  last_edited_request_notes request_note[] @relation("RequestNoteEditor")
  created_quote_notes       quote_note[]   @relation("QuoteNoteCreator")
  last_edited_quote_notes   quote_note[]   @relation("QuoteNoteEditor")
  created_recurring_plan_notes      recurring_plan_note[] @relation("RecurringPlanNoteCreator")
  last_edited_recurring_plan_notes  recurring_plan_note[] @relation("RecurringPlanNoteEditor")

  recorded_invoice_payments    invoice_payment[]
  created_invoice_notes        invoice_note[]    @relation("InvoiceNoteCreator")
  last_edited_invoice_notes    invoice_note[]    @relation("InvoiceNoteEditor")

  @@index([email])
  @@index([status])
  @@index([organization_id])
} 

model dispatcher {
  id          String   @id @unique @default(uuid())
  organization_id String?
  role            DispatcherRole @default(dispatcher)
  organization    organization? @relation(fields: [organization_id], references: [id])
  name        String
  email       String   @unique
  phone       String?
  password    String
  title       String
  description String
  last_login  DateTime @default(now())

  created_requests        request[]        @relation("RequestCreator")
  created_quotes          quote[]          @relation("QuoteCreator")
  created_recurring_plans recurring_plan[] @relation("RecurringPlanCreator")
  created_invoices        invoice[]

  created_client_notes      client_note[]  @relation("ClientNoteCreator")
  last_edited_client_notes  client_note[]  @relation("ClientNoteEditor")
  created_job_notes         job_note[]     @relation("JobNoteCreator")
  last_edited_job_notes     job_note[]     @relation("JobNoteEditor")
  created_request_notes     request_note[] @relation("RequestNoteCreator")
  last_edited_request_notes request_note[] @relation("RequestNoteEditor")
  created_quote_notes       quote_note[]   @relation("QuoteNoteCreator")
  last_edited_quote_notes   quote_note[]   @relation("QuoteNoteEditor")

  created_recurring_plan_notes     recurring_plan_note[] @relation("RecurringPlanNoteCreator")
  last_edited_recurring_plan_notes recurring_plan_note[] @relation("RecurringPlanNoteEditor")

  recorded_invoice_payments    invoice_payment[]
  created_invoice_notes        invoice_note[]    @relation("InvoiceNoteCreator")
  last_edited_invoice_notes    invoice_note[]    @relation("InvoiceNoteEditor")

  @@index([email])
  @@index([organization_id])
}

// ============================================================================
// LOGGING 
// ============================================================================

model log {
  id String @id @default(uuid())
  organization_id String?
  organization    organization? @relation(fields: [organization_id], references: [id])

  event_type  String // "client_note.created", "job.status_changed", "quote.sent"
  action      String // "created", "updated", "deleted", "viewed", "sent"
  entity_type String // "client_note", "job", "request", "quote", "client"
  entity_id   String // UUID of the entity

  actor_type String // "technician", "dispatcher", "system"
  actor_id   String?
  actor_name String?

  changes Json? // { field_name: { old: "...", new: "..." } }

  timestamp  DateTime @default(now())
  ip_address String?
  user_agent String?

  reason String?

  @@index([entity_type, entity_id])
  @@index([event_type])
  @@index([action])
  @@index([timestamp])
  @@index([actor_type, actor_id])
  @@index([actor_type])
  @@index([organization_id])
}

// ============================================================================
// INVOICING
// ============================================================================

model invoice_schedule {
  id                String                         @id @default(uuid())
  recurring_plan_id String                         @unique
  recurring_plan    recurring_plan                 @relation(fields: [recurring_plan_id], references: [id], onDelete: Cascade)
  frequency         invoice_schedule_frequency
  billing_basis     invoice_schedule_billing_basis
  fixed_amount      Decimal?                       @db.Decimal(10, 2)
  day_of_month      Int?
  day_of_week       weekday?
  generate_days_before Int                         @default(0)
  payment_terms_days   Int?
  auto_send         Boolean                        @default(false)
  memo_template     String?
  next_invoice_at   DateTime?
  last_invoiced_at  DateTime?
  is_active         Boolean                        @default(true)
  created_at        DateTime                       @default(now())
  updated_at        DateTime                       @updatedAt

  @@index([recurring_plan_id])
  @@index([is_active])
  @@index([is_active, next_invoice_at])
}

model invoice {
  id                       String         @id @default(uuid())
  organization_id          String?
  organization             organization?  @relation(fields: [organization_id], references: [id], onDelete: SetNull)
  invoice_number           String         @unique
  client_id                String
  client                   client         @relation(fields: [client_id], references: [id], onDelete: Restrict)
  status                   invoice_status @default(Draft)
  recurring_plan_id        String?
  recurring_plan           recurring_plan? @relation(fields: [recurring_plan_id], references: [id], onDelete: SetNull)
  issue_date               DateTime       @default(now())
  due_date                 DateTime?
  payment_terms_days       Int?
  sent_at                  DateTime?
  viewed_at                DateTime?
  paid_at                  DateTime?
  voided_at                DateTime?
  void_reason              String?
  subtotal                 Decimal        @default(0) @db.Decimal(10, 2)
  tax_rate                 Decimal        @default(0) @db.Decimal(5, 4)
  tax_amount               Decimal        @default(0) @db.Decimal(10, 2)
  discount_type            discount_type?
  discount_value           Decimal?       @db.Decimal(10, 2)
  discount_amount          Decimal?       @db.Decimal(10, 2)
  total                    Decimal        @default(0) @db.Decimal(10, 2)
  amount_paid              Decimal        @default(0) @db.Decimal(10, 2)
  balance_due              Decimal        @default(0) @db.Decimal(10, 2)
  memo                     String?
  internal_notes           String?
  created_at               DateTime       @default(now())
  updated_at               DateTime       @updatedAt
  created_by_dispatcher_id String?
  created_by_dispatcher    dispatcher?    @relation(fields: [created_by_dispatcher_id], references: [id], onDelete: SetNull)

  line_items invoice_line_item[]
  jobs       invoice_job[]
  visits     invoice_visit[]
  payments   invoice_payment[]
  notes      invoice_note[]

  @@index([client_id])
  @@index([organization_id])
  @@index([status])
  @@index([invoice_number])
  @@index([issue_date])
  @@index([due_date])
  @@index([recurring_plan_id])
  @@index([client_id, status])
}

model invoice_line_item {
  id              String         @id @default(uuid())
  invoice_id      String
  invoice         invoice        @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  source_job_id   String?
  source_visit_id String?
  name            String
  description     String?
  quantity        Decimal        @db.Decimal(10, 2)
  unit_price      Decimal        @db.Decimal(10, 2)
  total           Decimal        @db.Decimal(10, 2)
  item_type       line_item_type?
  sort_order      Int            @default(0)

  @@index([invoice_id])
  @@index([sort_order])
}

model invoice_job {
  invoice_id    String
  invoice       invoice  @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  job_id        String
  job           job      @relation(fields: [job_id], references: [id], onDelete: Restrict)
  billed_amount Decimal? @db.Decimal(10, 2)

  @@id([invoice_id, job_id])
  @@index([job_id])
  @@index([invoice_id])
}

model invoice_visit {
  invoice_id    String
  invoice       invoice   @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  visit_id      String
  visit         job_visit @relation(fields: [visit_id], references: [id], onDelete: Restrict)
  billed_amount Decimal   @db.Decimal(10, 2)

  @@id([invoice_id, visit_id])
  @@index([visit_id])
  @@index([invoice_id])
}

model invoice_payment {
  id                        String      @id @default(uuid())
  invoice_id                String
  invoice                   invoice     @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  amount                    Decimal     @db.Decimal(10, 2)
  paid_at                   DateTime    @default(now())
  method                    String?
  note                      String?
  recorded_by_dispatcher_id String?
  recorded_by_dispatcher    dispatcher? @relation(fields: [recorded_by_dispatcher_id], references: [id], onDelete: SetNull)
  recorded_by_tech_id       String?
  recorded_by_tech          technician? @relation(fields: [recorded_by_tech_id], references: [id], onDelete: SetNull)
  created_at                DateTime    @default(now())

  @@index([invoice_id])
  @@index([paid_at])
  @@index([recorded_by_tech_id])
}

model invoice_note {
  id                        String        @id @default(uuid())
  organization_id           String?
  organization              organization? @relation(fields: [organization_id], references: [id], onDelete: SetNull)
  invoice_id                String
  invoice                   invoice       @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  content                   String
  created_at                DateTime      @default(now())
  updated_at                DateTime      @updatedAt
  creator_tech_id           String?
  creator_tech              technician?   @relation("InvoiceNoteCreator", fields: [creator_tech_id], references: [id], onDelete: SetNull)
  creator_dispatcher_id     String?
  creator_dispatcher        dispatcher?   @relation("InvoiceNoteCreator", fields: [creator_dispatcher_id], references: [id], onDelete: SetNull)
  last_editor_tech_id       String?
  last_editor_tech          technician?   @relation("InvoiceNoteEditor", fields: [last_editor_tech_id], references: [id], onDelete: SetNull)
  last_editor_dispatcher_id String?
  last_editor_dispatcher    dispatcher?   @relation("InvoiceNoteEditor", fields: [last_editor_dispatcher_id], references: [id], onDelete: SetNull)

  @@index([invoice_id])
}

// ============================================================================
// Verification tokens 
// ============================================================================

model otp_verification {
  id        String   @id @default(cuid())
  userId    String
  role      String   // 'dispatcher' | 'technician'
  otp       String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId, role])
}

model jwt_refresh_token {
  id        String   @id @default(cuid())
  userId    String
  role      String   // 'dispatcher' | 'technician'
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId, role])
}