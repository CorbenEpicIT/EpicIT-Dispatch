{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "node",
		"outDir": "./dist",
		"rootDir": "./",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"jsx": "react-jsx"
	},
	"include": ["*.ts", "src/**/*.ts", "src/**/*.tsx"],
	"exclude": ["src/**/__tests__/**"]
}
